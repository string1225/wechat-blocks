{
  "name": "wechat-blocks",
  "version": "0.1.0",
  "private": true,
  "description": "3D block elimination prototype for a WeChat Mini Game.",
  "scripts": {
    "dev": "webpack serve --config webpack.config.cjs --mode development",
    "build": "webpack --config webpack.config.cjs --mode production",
    "typecheck": "tsc --noEmit",
    "wechat:check": "node scripts/wechat-ci.cjs check",
    "wechat:preview": "npm run build && node scripts/wechat-ci.cjs preview",
    "wechat:upload": "npm run build && node scripts/wechat-ci.cjs upload"
  },
  "license": "MIT",
  "dependencies": {
    "lucide": "^1.17.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.1",
    "copy-webpack-plugin": "^14.0.0",
    "html-webpack-plugin": "^5.6.7",
    "miniprogram-ci": "2.1.31",
    "ts-loader": "^9.6.0",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4"
  }
}
